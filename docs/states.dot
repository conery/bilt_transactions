digraph { 
    rankdir = "LR";
    node [shape = doublecircle]; A,N;
    node [shape = circle];
    edge [fontsize = 10];
    edge [fontcolor = "blue"];
    A -> D [label = "  date   "];
    D -> X [label = " desc    "];
    X -> N [label = " amt"];
    X -> X [label = "desc"];
    N -> D [label = " date"];
    N -> X [label = "  desc"];
